# .env.example
# 이 파일을 복사하여 .env 파일을 생성하세요.
#   macOS/Linux: cp .env.example .env
#   Windows:     copy .env.example .env
#
# .env 파일은 .gitignore에 포함되어 저장소에 커밋되지 않습니다.
# 실제 운영 값은 팀 내부 채널을 통해 공유됩니다.

# 실행 환경 (development | production)
FLUTTER_ENV=development

# 로그 출력 수준 (debug | info | warn | error)
APP_LOG_LEVEL=debug
